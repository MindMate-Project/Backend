# ---- Core ----
PORT=4000
MONGO_URL=mongodb+srv://user:pass@cluster/db
JWT_SECRET_KEY=replace-with-a-long-random-secret
BACKEND_URL=https://your-backend.example.com
NODE_ENV=development

# CORS: comma-separated allowed origins (empty = allow all)
ALLOWED_ORIGINS=

# ---- Email (Brevo) ----
BREVO_API_KEY=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=MindMate

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Firebase (FCM push) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- IoT / MQTT (patient location) ----
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ---- Python AI face service ----
PYTHON_AI_URL=http://your-ai-host:8000
# Shared secret; must equal INTERNAL_API_KEY on the AI service to enforce auth
PYTHON_AI_KEY=
