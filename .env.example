# Server
PORT=4000

# Auth
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Database
MONGO_URL=mongodb://127.0.0.1:27017/mindmate

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Brevo Email API
BREVO_API_KEY=your_brevo_api_key

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep escaped newlines (\n) if you paste the key in one line.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# MQTT / IoT
# Example: mqtt://localhost:1883
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Python AI service (Face recognition endpoint)
# Example: http://127.0.0.1:5000
PYTHON_AI_URL=http://127.0.0.1:5000
