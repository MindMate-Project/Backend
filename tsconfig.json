{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./backend/dist",
    "rootDir": "./backend/src",
     "allowJs": true,
    "checkJs": true,
     "noEmit": false,
     //"allowImportingTsExtensions":true
  },
  "include": ["backend/src/**/*", "backend/src/types/**/*"],
  "exclude": ["node_modules"]
}