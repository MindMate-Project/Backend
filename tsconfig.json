{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "backend/src",
    "outDir": "backend/dist",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node", "express"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "noEmit": false,

    "allowJs": false,
    "checkJs": false
  },
  "include": ["backend/src/**/*"],
  "exclude": ["node_modules", "backend/dist"]
}
